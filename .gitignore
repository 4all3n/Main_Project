# =============================================================================
# MindfulMomentum — Root .gitignore
# =============================================================================

# =============================================================================
# BACKEND (backend/)
# =============================================================================

# PMData raw dataset — too large (~1 GB), download separately
backend/Data/

# Python virtual environment
backend/.venv/

# Cached ML model files — regenerated by running the backend
backend/saved_models/

# Auto-generated visualisation graphs
backend/output_graphs/

# Python bytecode cache
backend/__pycache__/
backend/**/__pycache__/
*.py[cod]
*$py.class

# Python distribution / packaging artifacts
backend/*.egg-info/
backend/dist/
backend/build/

# =============================================================================
# RESEARCH (research/)
# =============================================================================

# Research virtual environment (separate from backend)
research/.venv/

# Fine-tuned transformer model weights — large (~500 MB), regenerated by notebook 04
research/fine_tuned_model/

# HuggingFace cache directory (can also appear at ~/.cache/huggingface)
research/.cache/
.cache/huggingface/

# Optuna SQLite study database (if used)
research/*.db
research/optuna_study.db

# Python bytecode
research/__pycache__/
research/**/__pycache__/

# Jupyter checkpoint files
research/**/.ipynb_checkpoints/
.ipynb_checkpoints/

# NOTE: The following are intentionally TRACKED in git:
#   research/figures/       ← publication-ready PNG figures
#   research/results/       ← CSV result tables + per-user JSON configs
#   research/notebooks/     ← .py and .ipynb research scripts
#   research/requirements_research.txt

# =============================================================================
# MOBILE APP (mobile-app/)
# =============================================================================

# Node.js dependencies
mobile-app/node_modules/

# Expo / Metro build cache
mobile-app/.expo/
mobile-app/dist/
mobile-app/web-build/
mobile-app/expo-env.d.ts
mobile-app/.metro-health-check*

# Generated native Android and iOS project folders
# (Re-generated by `npx expo run:android` / `npx expo prebuild`)
mobile-app/android/
mobile-app/ios/
mobile-app/.kotlin/

# Keystore and signing certificates — never commit private keys
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# TypeScript incremental build info
*.tsbuildinfo

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# Local environment variable files
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# =============================================================================
# EDITORS & OPERATING SYSTEMS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# JetBrains IDEs (IntelliJ, PyCharm, WebStorm, Android Studio)
.idea/
*.iml
*.iws
*.ipr

# VSCode
.vscode/
!.vscode/settings.json     # Keep shared workspace settings if desired
!.vscode/extensions.json   # Keep recommended extensions list if desired

# Vim / Neovim swap files
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# =============================================================================
# SECRETS & CREDENTIALS — NEVER COMMIT
# =============================================================================
.env
secrets.json
google-services.json
GoogleService-Info.plist

# =============================================================================
# MISC
# =============================================================================

# Test coverage reports
coverage/
.coverage
htmlcov/

# Pytest cache
.pytest_cache/

# MyPy type checker cache
.mypy_cache/

# Ruff linter cache
.ruff_cache/